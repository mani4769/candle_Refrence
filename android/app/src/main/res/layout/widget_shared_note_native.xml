<?xml version="1.0" encoding="utf-8"?>
<!-- Removed margin so black background fills the widget -->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
  android:id="@+id/widget_root"
  android:layout_width="match_parent"
  android:layout_height="match_parent"
  android:background="@drawable/widget_note_rounded_bg"
  android:clickable="true"
  android:focusable="true"
  android:orientation="vertical"
  android:paddingLeft="16dp"
  android:paddingTop="14dp"
  android:paddingRight="16dp"
  android:paddingBottom="16dp">

  <LinearLayout
    android:layout_width="wrap_content"
    android:layout_height="wrap_content"
    android:orientation="horizontal"
    android:gravity="center_vertical">

    <ImageView
      android:id="@+id/widget_logo"
      android:layout_width="18dp"
      android:layout_height="28dp"
      android:layout_marginRight="6dp"
      android:src="@drawable/widget_spark_logo"
      android:contentDescription="Spark logo" />

    <ImageView
      android:id="@+id/widget_wordmark"
      android:layout_width="64dp"
      android:layout_height="11dp"
      android:src="@drawable/widget_spark_wordmark"
      android:scaleType="fitStart"
      android:contentDescription="spark" />
  </LinearLayout>

  <ImageView
    android:id="@+id/widget_drawing"
    android:layout_width="match_parent"
    android:layout_height="0dp"
    android:layout_marginTop="14dp"
    android:layout_weight="1"
    android:adjustViewBounds="true"
    android:contentDescription="Drawing"
    android:scaleType="fitCenter" />

</LinearLayout>
